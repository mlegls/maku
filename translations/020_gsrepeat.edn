;; Translation of dmk-corpus/020_gsrepeat.bdsl
;;
;; BDSL original (22 lines), for ergonomics comparison:
;;
;;   pattern { } {
;;   phase 0 {
;;       roott(1, 0, 1)
;;   } {
;;       paction 0 {
;;           sync("scircle-blue/b", <>, gsrepeat({
;;                   times(14)
;;                   circle
;;                   sfx("x-fire-burst-1")
;;               }, s(rvelocity(px(2))))
;;           )
;;       }
;;       paction 1 {
;;           sync("scircle-red/w", <>, gsrepeat({
;;                   times(10)
;;                   circle
;;                   sfx("x-fire-burst-2")
;;               }, s(rvelocity(px(3))))
;;           )
;;       }
;;   }
;;   }
;;
;; DMK semantics: emitter settles at (0, 1); at t=0 a synchronous ring of 14 blue
;; circles fires outward at speed 2; at t=1s a ring of 10 red circles at speed 3.

(defpattern gsrepeat-demo []
  ((pose c[0 1])                       ; lexical anchor; no global emitter.
    (par                                    ; DMK roott animates the boss entity;
      (seq                                  ; the pattern only anchors.
        (event :sfx "x-fire-burst-1")
        (spawn (circle 14 (linear c[2 0]))
               {:style "scircle-blue/b"}))
      (seq
        (wait 1.0)
        (event :sfx "x-fire-burst-2")
        (spawn (circle 10 (linear c[3 0]))
               {:style "scircle-red/w"})))))

;; ---------------------------------------------------------------------------
;; Canonical desugared tree (spawn argument, first volley)
;;
;; (circle 14 <child>) is trailing-child sugar; ((pose ...) <actions>) is an
;; applicable frame. Both desugar to in-frame. Each pose in (circle 14)
;; promotes to a Closed-const dyn (constants are the unit of both algebras,
;; SS4), then in-frame broadcasts elementwise with the scalar child lifted
;; (SS5). It IS ordinary map -- no special frame-broadcast rule:
;;
;;   (in-frame (pose (cart 0 1))
;;     (map (fn [p] (in-frame p (linear (cart 2 0))))
;;          (circle 14)))
;;
;; The inline (linear ...) is nominally fresh-per-element, but linear is Closed/
;; stateless, so instance identity is moot (finding F2).
;;
;; ---------------------------------------------------------------------------
;; Rate / constructor audit
;;
;;   (pose c[0 1])          constant anchor, promoted Closed-const ....... ir
;;                          (would be kr if a live entity frame)
;;   (circle 14)            value: Array Pose (theta column = !14 x 2pi/14),
;;                          promoted to Closed-const per element ......... ir
;;   (linear c[2 0])        Closed (tau -> v*tau), references bullet-local
;;                          tau only .................................... ar
;;                          (cohort note F6: all 14 born same tick =>
;;                          value shared across the cohort each frame)
;;   (in-frame _ _)         Closed . Closed = Closed ..................... ar
;;   meta {:style ...}      constant .................................... ir
;;   volley timeline        waits are constants, no event-waits
;;                          => input-independent: scrubbable, extractable
;;
;; DMK's s(rvelocity(px(2))) is Scanned as written; translated to the Closed
;; position form per finding F1.
;;
;; Nothing in this script lacks a clean image.
